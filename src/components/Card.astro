---
interface Props {
  className?: string;
  title?: string;
  delay?: number;
}

const { className = "", title, delay = 0 } = Astro.props;
---

<div
  class={`bento-card reveal relative overflow-hidden ${className} group`}
  data-delay={delay}
>
  <div
    class="glass-content p-8 h-full flex flex-col relative z-10 transition-transform duration-700 group-hover:scale-[0.99] border border-white/5 group-hover:border-emerald-500/30 rounded-[32px]"
  >
    {
      title && (
        <div class="flex items-center gap-2 mb-6">
          <div class="w-1 h-1 rounded-full bg-emerald-500 animate-pulse" />
          <h3 class="text-[10px] font-bold text-zinc-500 tracking-[0.3em] uppercase">
            {title}
          </h3>
        </div>
      )
    }
    <slot />
  </div>

  <!-- Content Hover Background -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-white/[0.03] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"
  >
  </div>
</div>

<style>
  .bento-card {
    background: rgba(255, 255, 255, 0.01);
    border-radius: 32px;
    height: 100%;
  }

  .glass-content {
    background: radial-gradient(
      100% 100% at 0% 0%,
      rgba(255, 255, 255, 0.03) 0%,
      rgba(255, 255, 255, 0) 100%
    );
  }
</style>
